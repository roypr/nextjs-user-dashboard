# =============================================================================
# Environment Variables — User Management System + CMS
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Database ---
# PostgreSQL connection string for Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/nextjs_user_dashboard"

# --- Session Encryption ---
# Secret key for JWE session encryption (AES-256-GCM).
# Must be at least 32 characters long.
SESSION_SECRET="your-session-secret-at-least-32-characters-long"

# --- Super Admin ---
# Email address of the Super Admin user (created by seed script).
SUPER_ADMIN_EMAIL="admin@example.com"
# Initial password for the Super Admin user (used by seed script).
SUPER_ADMIN_PASSWORD="your-strong-password"

# --- SMTP (Email) ---
# SMTP server configuration for sending verification and password reset emails.
# Resend (resend.com) is recommended, but any SMTP provider works.
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend-api-key"
SMTP_PASS="resend-api-key"
# "From" address for outgoing emails.
SMTP_FROM="noreply@yourdomain.com"

# --- Site URL ---
# Public-facing URL of the site. Used for email links and SEO metadata.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Upstash Redis (Rate Limiting) ---
# Redis connection URL and token for Upstash rate limiting.
# Sign up at https://upstash.com for a free tier.
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"
